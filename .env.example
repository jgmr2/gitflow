PORT=5100

# MongoDB
# Local/Docker: mongodb://admin:<password>@mongo:27017/projectdb?authSource=admin
# Produccion (Vercel): usar una URI accesible desde internet, ej. MongoDB Atlas
MONGO_URI=mongodb://admin:<password>@mongo:27017/projectdb?authSource=admin

# JWT
JWT_SECRET=your_jwt_secret_here

# API Key requerida en el header x-api-key para consumir /api/*
# Generar una nueva con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your_api_key_here
